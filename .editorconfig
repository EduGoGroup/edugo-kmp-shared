root = true

[*.{kt,kts}]
# Composables convencionalmente usan PascalCase. ktlint 1.3.1 ofrece la opción
# fina, pero el desactivado completo de la regla aplica también a propiedades
# como `Alpha.disabled` que se mantienen en camelCase por estabilidad de API
# pública de tokens.
ktlint_function_naming_ignore_when_annotated_with = androidx.compose.runtime.Composable
ktlint_standard_function-naming = disabled

# Constantes de tokens (`Alpha.disabled`, `Durations.splash`, …) son API pública
# de design-core; renombrar a SCREAMING_SNAKE rompería todos los consumidores.
ktlint_standard_property-naming = disabled

# Archivos de tokens agrupan declaraciones por dominio (Z-index, opacity, etc.);
# el nombre refleja el dominio aunque haya una sola declaración top-level.
ktlint_standard_filename = disabled
